# ── Supabase (database + auth + storage) ─────────────────────────────
# Get these from https://supabase.com → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Cloudflare R2 (file storage) ─────────────────────────────────────
# Proxy through your backend — never expose secret keys to the browser
VITE_FILE_UPLOAD_URL=http://localhost:4000/api/upload

# ── WhatsApp Business API (reminder notifications) ────────────────────
# Via Twilio or 360dialog — backend only
# WHATSAPP_API_KEY=your-key (set in backend .env, not here)

# ── App config ────────────────────────────────────────────────────────
VITE_APP_NAME=ComplyRMG
VITE_APP_ENV=development
